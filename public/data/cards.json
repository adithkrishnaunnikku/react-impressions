<!-- ========== MAIN CONTENT ========== -->
<main id="main-content">

    <!-- Our Story -->
    <section id="our-story" class="emotional-hook">
        <!-- ... unchanged ... -->
    </section>

    <!-- Collections -->
    <section id="collections" class="categories">
        <div class="section-header">
            <h2>Our Collections</h2>
            <div class="divider"></div>
            <p class="section-subtitle">Curated categories of timeless artistry.</p>
        </div>
        <div class="category-grid" id="category-grid">
            <!-- Dynamically populated from cards.json -->
        </div>
    </section>

    <!-- Portfolio / Shop -->
    <section id="portfolio" class="products-section">
        <div class="section-header">
            <h2>The Portfolio</h2>
            <p>Hover to preview. Click for details. Each piece is a testament to craftsmanship.</p>
            <div class="divider"></div>
        </div>
        <div class="search-wrapper">
            <input type="text" id="portfolio-search" placeholder="Search designs...">
        </div>
        <div class="sort-wrapper">
            <select id="portfolio-sort" aria-label="Sort designs">
                <option value="featured">Featured</option>
                <option value="price-asc">Price: Low to High</option>
                <option value="price-desc">Price: High to Low</option>
            </select>
        </div>
        <div class="filter-container" id="filter-container">
            <button class="filter-btn active" data-filter="All">All Designs</button>
        </div>
        <div class="products-grid" id="product-container"></div>
        <div class="show-more-container">
            <button id="show-more-btn" class="show-more-btn" aria-label="Show more designs">Show More Designs</button>
        </div>
    </section>

</main>

<!-- ========== QUICK VIEW MODAL ========== -->
<div id="quick-view-modal" class="modal-overlay" role="dialog" aria-modal="true" aria-labelledby="modal-title">
    <div class="modal-content">
        <button class="close-modal" id="close-modal" aria-label="Close modal">&#215;</button>
        <div class="modal-body">
            <div class="modal-gallery">
                <div class="main-image-container">
                    <img id="modal-main-img" src="" alt="Card design preview">
                    <button class="modal-share-btn" id="modal-share-btn" aria-label="Copy shareable link" title="Copy link to this design">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
                            <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
                        </svg>
                    </button>
                </div>
                <div class="thumbnail-row" id="modal-thumbnails"></div>
            </div>
            <div class="modal-info">
                <p class="modal-category" id="modal-category-label">Allure Exclusive</p>
                <h3 id="modal-title">Product ID</h3>
                <p class="modal-price" id="modal-unit-price">Rs. 0 / card</p>
                <div class="modal-description">
                    <p id="modal-desc-text">Experience the timeless elegance of this design. Crafted on premium materials with exquisite detailing.</p>
                </div>
                <p id="modal-details" class="modal-details"></p>
                <div class="calculator-box">
                    <div class="input-group">
                        <label for="modal-qty-select">Number of Cards</label>
                        <select id="modal-qty-select"></select>
                        <p class="discount-banner" id="discount-banner">5% off on 500+ &nbsp;·&nbsp; 10% off on 1000+</p>
                    </div>
                    <div class="calc-summary">
                        <div class="summary-row">
                            <span>Card Cost</span>
                            <span id="calc-card-cost">Rs. 0</span>
                        </div>
                        <div class="summary-row" id="printing-row">
                            <span>Printing Charge</span>
                            <span id="calc-printing-val">Rs. 600</span>
                        </div>
                        <div class="summary-row highlight-discount" id="discount-row" style="display:none;">
                            <span>Volume Discount</span>
                            <span id="calc-discount-val">—</span>
                        </div>
                        <div class="summary-row highlight-save" id="savings-row" style="display:none;">
                            <span>You Save</span>
                            <span id="calc-savings-val">Rs. 0</span>
                        </div>
                        <div class="divider-sm"></div>
                        <div class="summary-row total-row">
                            <span>Final Estimate</span>
                            <span id="calc-final-total">Rs. 0</span>
                        </div>
                    </div>
                </div>
                <a href="#"
                   id="modal-whatsapp-btn"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="whatsapp-cta-btn"
                   aria-label="Order this design via WhatsApp">
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512" aria-hidden="true">
                        <path d="M380.9 97.1C339 55.1 283.2 32 223.9 32c-122.4 0-222 99.6-222 222 0 39.1 10.2 77.3 29.6 111L0 480l117.7-30.9c32.4 17.7 68.9 27 106.1 27h.1c122.3 0 224.1-99.6 224.1-222 0-59.3-25.2-115-67.1-157.1zm-157 341.6c-33.2 0-65.7-8.9-94-25.7l-6.7-4-69.8 18.3L72 359.2l-4.4-7c-18.5-29.4-28.2-63.3-28.2-98.2 0-101.7 82.8-184.5 184.6-184.5 49.3 0 95.6 19.2 130.4 54.1 34.8 34.9 56.2 81.2 56.1 130.5 0 101.8-84.9 184.6-186.6 184.6zm101.2-138.2c-5.5-2.8-32.8-16.2-37.9-18-5.1-1.9-8.8-2.8-12.5 2.8-3.7 5.6-14.3 18-17.6 21.8-3.2 3.7-6.5 4.2-12 1.4-32.6-16.3-54-29.1-75.5-66-5.7-9.8 5.7-9.1 16.3-30.3 1.8-3.7.9-6.9-.5-9.7-1.4-2.8-12.5-30.1-17.1-41.2-4.5-10.8-9.1-9.3-12.5-9.5-3.2-.2-6.9-.2-10.6-.2-3.7 0-9.7 1.4-14.8 6.9-5.1 5.6-19.4 19-19.4 46.3 0 27.3 19.9 53.7 22.6 57.4 2.8 3.7 39.1 59.7 94.8 83.8 35.2 15.2 49 16.5 66.6 13.9 10.7-1.6 32.8-13.4 37.4-26.4 4.6-13 4.6-24.1 3.2-26.4-1.3-2.5-5-3.9-10.5-6.6z"/>
                    </svg>
                    Order via WhatsApp
                </a>
            </div>
        </div>
    </div>
</div>

<!-- ========== FULL-SCREEN LIGHTBOX ========== -->
<div id="gallery-overlay" class="gallery-overlay" role="dialog" aria-modal="true" aria-label="Full screen image preview">
    <button class="gallery-close" id="gallery-close" aria-label="Close full-screen preview">&#215;</button>
    <button class="gallery-nav gallery-prev" id="gallery-prev" aria-label="Previous image">&#8249;</button>
    <button class="gallery-nav gallery-next" id="gallery-next" aria-label="Next image">&#8250;</button>
    <img id="gallery-img" src="" alt="Full screen preview">
    <p id="gallery-counter" class="gallery-counter"></p>
</div>